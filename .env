# -------------------------------------------------------
# Movie Recommendation App – Environment Variables
# -------------------------------------------------------

# OMDb API key (required) – get a free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=cc06e4a2

# Gemini API key (optional) – enables AI summaries and smarter candidate selection
# GEMINI_API_KEY=your_gemini_key_here

# Gemini model to use (optional, defaults to gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Flask secret key (optional – change this in production)
# FLASK_SECRET_KEY=change-me-in-production
